rules_version = '2';

// CuidaBem - regras do Firestore.
// Todo o acesso aos dados e mediado pelo back-end (Firebase Admin SDK), que
// ignora estas regras. Portanto, o acesso direto de clientes e negado por
// padrao (defesa em profundidade / RN003). A identidade e validada pelo
// back-end via verifyIdToken antes de qualquer operacao.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
