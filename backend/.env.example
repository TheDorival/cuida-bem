# Ambiente: development | production
NODE_ENV=development
PORT=3000

# Backend de persistencia/identidade: memory | firebase
# memory  -> repositorios em memoria + notificacoes via console (dev/testes)
# firebase-> Firestore + Firebase Auth + FCM (producao)
DATA_BACKEND=memory

# Armazenamento dos PDFs de relatorio: local | firebase
# Use 'local' para nao depender do Firebase Storage (que exige o plano Blaze);
# os PDFs ficam servidos pelo proprio back-end em /reports.
# Se vazio, segue o DATA_BACKEND.
STORAGE_BACKEND=local

# Credenciais Firebase (apenas quando DATA_BACKEND=firebase)
# Caminho para o JSON da service account OU as variaveis abaixo
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Base URL usada para montar links de convite (UC002)
APP_BASE_URL=http://localhost:3000

# Segredo compartilhado para o endpoint de job de alertas (Cloud Scheduler)
JOB_SECRET=troque-este-segredo
# Habilita o agendador de alertas em processo (true/false)
ALERTAS_EM_PROCESSO=false
